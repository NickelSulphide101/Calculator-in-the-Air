<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Window backdrops -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F2141419" />
    
    <LinearGradientBrush x:Key="WindowBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4DA78BFA" Offset="0.0" />
        <GradientStop Color="#4D67E8F9" Offset="0.5" />
        <GradientStop Color="#1AFFFFFF" Offset="1.0" />
    </LinearGradientBrush>

    <sys:Double x:Key="ShadowOpacity">0.55</sys:Double>

    <LinearGradientBrush x:Key="CalculatorIconBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#A78BFA" Offset="0.0" />
        <GradientStop Color="#67E8F9" Offset="1.0" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="PlaceholderForegroundBrush" Color="#6E737D" />
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputCaretBrush" Color="#A78BFA" />
    <SolidColorBrush x:Key="InputSelectionBrush" Color="#648B5CF6" />
    
    <SolidColorBrush x:Key="SeparatorBrush" Color="#14FFFFFF" />
    <SolidColorBrush x:Key="EqualsLabelBrush" Color="#A78BFA" />
    
    <LinearGradientBrush x:Key="ResultForegroundBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#A78BFA" Offset="0.0" />
        <GradientStop Color="#67E8F9" Offset="1.0" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="HintForegroundBrush" Color="#6E737D" />

    <!-- Settings Window Specifics -->
    <SolidColorBrush x:Key="SettingsBackgroundBrush" Color="#18181C" />
    <SolidColorBrush x:Key="SettingsForegroundBrush" Color="#FFFFFF" />
    
    <LinearGradientBrush x:Key="SettingsHeaderBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#A78BFA" Offset="0.0" />
        <GradientStop Color="#67E8F9" Offset="1.0" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="SettingsLabelForegroundBrush" Color="#AAAAA9" />
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="#282830" />
    <SolidColorBrush x:Key="ComboBoxForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#3C3C48" />

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#282830" />
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#373744" />
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#3C3C48" />
</ResourceDictionary>
