<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Window backdrops -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F2F5F5F7" />
    
    <LinearGradientBrush x:Key="WindowBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4D8B5CF6" Offset="0.0" />
        <GradientStop Color="#4D06B6D4" Offset="0.5" />
        <GradientStop Color="#1A000000" Offset="1.0" />
    </LinearGradientBrush>

    <sys:Double x:Key="ShadowOpacity">0.15</sys:Double>

    <LinearGradientBrush x:Key="CalculatorIconBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#7C3AED" Offset="0.0" />
        <GradientStop Color="#0D9488" Offset="1.0" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="PlaceholderForegroundBrush" Color="#787D87" />
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#1E1E23" />
    <SolidColorBrush x:Key="InputCaretBrush" Color="#7C3AED" />
    <SolidColorBrush x:Key="InputSelectionBrush" Color="#328B5CF6" />
    
    <SolidColorBrush x:Key="SeparatorBrush" Color="#14000000" />
    <SolidColorBrush x:Key="EqualsLabelBrush" Color="#7C3AED" />
    
    <LinearGradientBrush x:Key="ResultForegroundBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#7C3AED" Offset="0.0" />
        <GradientStop Color="#0D9488" Offset="1.0" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="HintForegroundBrush" Color="#787D87" />

    <!-- Settings Window Specifics -->
    <SolidColorBrush x:Key="SettingsBackgroundBrush" Color="#F5F5F7" />
    <SolidColorBrush x:Key="SettingsForegroundBrush" Color="#1E1E23" />
    
    <LinearGradientBrush x:Key="SettingsHeaderBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#7C3AED" Offset="0.0" />
        <GradientStop Color="#0D9488" Offset="1.0" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="SettingsLabelForegroundBrush" Color="#50505F" />
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ComboBoxForegroundBrush" Color="#1E1E23" />
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#C8C8D2" />

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#EBEBF0" />
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#DCDCD2" />
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#1E1E23" />
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#C8C8D2" />
</ResourceDictionary>
