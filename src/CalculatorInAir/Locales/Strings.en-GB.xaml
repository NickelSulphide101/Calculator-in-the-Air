<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Placeholder">Type a math formula... (e.g. 2pi * 5 or sqrt(16))</sys:String>
    <sys:String x:Key="PressEnterToCopy">Press Enter to copy</sys:String>
    <sys:String x:Key="Copied">Copied to clipboard!</sys:String>
    <sys:String x:Key="TrayShow">Show Calculator</sys:String>
    <sys:String x:Key="TraySettings">Settings...</sys:String>
    <sys:String x:Key="TrayExit">Exit</sys:String>
    <sys:String x:Key="SettingsTitle">Settings - Calculator in the Air</sys:String>
    <sys:String x:Key="GlobalShortcut">Global Shortcut:</sys:String>
    <sys:String x:Key="RecordHotkey">Record Hotkey</sys:String>
    <sys:String x:Key="RecordingPrompt">Press keys... (Esc to cancel)</sys:String>
    <sys:String x:Key="Precision">Calculation Precision (decimals):</sys:String>
    <sys:String x:Key="PrecisionAuto">Auto</sys:String>
    <sys:String x:Key="Behavior">Behavior Settings:</sys:String>
    <sys:String x:Key="HideOnBlur">Hide when focus is lost</sys:String>
    <sys:String x:Key="CopyOnEnter">Copy result on pressing Enter</sys:String>
    <sys:String x:Key="LanguageSetting">Interface Language:</sys:String>
    <sys:String x:Key="LanguageAuto">Follow System (Auto)</sys:String>
    <sys:String x:Key="ThemeSetting">Theme:</sys:String>
    <sys:String x:Key="ThemeAuto">Follow System (Auto)</sys:String>
    <sys:String x:Key="ThemeDark">Dark Mode</sys:String>
    <sys:String x:Key="ThemeLight">Light Mode</sys:String>
    <sys:String x:Key="Save">Save</sys:String>
    <sys:String x:Key="Cancel">Cancel</sys:String>
    <sys:String x:Key="HotkeyConflict">Failed to register global hotkey '{0}'. It might be already in use by another application.</sys:String>
    <sys:String x:Key="HotkeyConflictTitle">Hotkey Conflict</sys:String>
    <sys:String x:Key="HotkeyWarningText">The shortcut must contain at least one modifier key (Ctrl, Alt, Shift, or Win) to prevent your keyboard keys from being locked globally!</sys:String>
    <sys:String x:Key="HotkeyWarningTitle">Unsafe Shortcut</sys:String>
</ResourceDictionary>
